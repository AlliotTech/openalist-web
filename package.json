    "url": "https://www.nn.ci"
  },
  "description": "The front end of Alist V3",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22.22.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlliotTech/openalist-web.git"
  },
  "bugs": {
    "url": "https://github.com/AlliotTech/openalist/issues"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://alist.iots.vip",
  "scripts": {
    "crowdin:upload": "crowdin upload sources --auto-update",
    "crowdin:download": "crowdin download --verbose",
    "crowdin": "pnpm crowdin:upload && pnpm crowdin:download",
    "i18n:build": "pnpm crowdin && node ./scripts/i18n.mjs",
    "i18n:release": "pnpm run crowdin:download && node ./scripts/i18n.mjs",
    "start": "vite",
    "dev": "vite --force",
    "build": "vite build",
    "serve": "vite preview",
    "prepare": "husky",
    "format": "prettier --ignore-path .gitignore -w \"src/**/*.{js,ts,json,css,tsx,jsx}\""
  },
  "license": "MIT",
  "devDependencies": {
    "@crowdin/cli": "^4.14.4",
    "@types/bencode": "^4.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/ini": "^4.1.1",
    "@types/mark.js": "^8.11.12",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/sha256": "^0.2.2",
    "@types/streamsaver": "^2.0.5",
    "@vitejs/plugin-legacy": "^8.2.1",
    "changelogithub": "14.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "3.9.6",
    "terser": "^5.49.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-dynamic-base": "^1.4.1",
    "vite-plugin-solid": "^2.11.13"
  },
